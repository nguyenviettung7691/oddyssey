# Google OAuth 2.0 Web Client ID for Google Sign-In.
# When omitted, the app gracefully falls back to guest mode.
# VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Genkit AI Flow endpoint URL for generating quiz questions.
# Point this to a deployed Genkit flow (e.g., on Cloud Functions for Firebase or Cloud Run).
# When omitted, the app uses the curated fallback question bank.
# VITE_GENKIT_API_URL=https://your-project.cloudfunctions.net/generateQuestion
